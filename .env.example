# Database Configuration
DATABASE_URL=postgresql://username:password@host:5432/database_name
DB_USER=your_db_user
DB_PASSWORD=your_db_password

# CORS Configuration (comma-separated list of allowed origins)
ALLOWED_ORIGINS=https://daily-wallet.vercel.app,https://daily-wallet-8ej6.onrender.com

# JWT Configuration
JWT_SECRET=your_super_secret_jwt_key_at_least_32_characters_long
JWT_EXPIRATION=86400000

# Server Configuration
SERVER_PORT=8080

# M-Pesa Configuration
MPESA_API_URL=https://api.safaricom.co.ke
MPESA_CONSUMER_KEY=your_mpesa_consumer_key
MPESA_CONSUMER_SECRET=your_mpesa_consumer_secret
MPESA_PASSKEY=your_mpesa_passkey
MPESA_SHORTCODE=your_mpesa_shortcode

# Alpha Vantage API Configuration (NSE Stock Data)
# Get your free API key from: https://www.alphavantage.co/support/#api-key
# Free tier: 25 requests/day, 5 requests/minute
ALPHA_VANTAGE_API_KEY=your_alpha_vantage_api_key

# Frontend Configuration
VITE_API_BASE_URL=https://daily-wallet-8ej6.onrender.com/api
VITE_APP_TITLE=Jimudu Wallet
VITE_APP_DESCRIPTION=Smart cash flow management for daily earners
VITE_ENABLE_PWA=true
VITE_APP_VERSION=1.0.0
